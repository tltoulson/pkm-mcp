# Host paths — Docker bind-mounts these into the container.
# Use forward slashes on Windows when running via Docker Desktop.
VAULT_PATH=C:/Users/tltou/OneDrive/claud-vault
INDEX_PATH=C:/Users/tltou/.pkm-index
MCP_PORT=8765
TZ=America/New_York

# Optional
# OAuth 2.1 — required for all deployments
# OAUTH_BASE_URL: the public URL clients connect to (Public URL or http://localhost:PORT for local dev)
# OAUTH_JWT_SECRET: random secret for signing access tokens — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OAUTH_PASSWORD: the password shown on the login form
OAUTH_BASE_URL=https://public-mcp-url.example.com
OAUTH_JWT_SECRET=change-me-generate-with-crypto-randomBytes-32
OAUTH_PASSWORD=change-me